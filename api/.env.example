# Copy to `.env` and fill in. Loaded by @nestjs/config (ConfigModule.forRoot)
# and validated at boot against src/env.validation.ts — a missing/blank
# required var crashes the process immediately instead of failing per-request.

# ── Database (MongoDB / Mongoose) ────────────────────────────────────────────
# MongoDB connection string. Consumed by Mongoose (`db:check` pings it via
# scripts/db-check.ts). Use your Atlas SRV URI.
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority"

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# The API is guarded by @clerk/express: every /api/* request must carry a
# valid Clerk session token. These are the same keys the web app uses (copy
# them from web/.env.local).
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ── Chat (GetStream.io) ──────────────────────────────────────────────────────
# Stream Chat app credentials. Create an app in the GetStream dashboard
# (https://dashboard.getstream.io) and copy its Key + Secret. The key is handed
# to the web client via POST /api/stream/token (never inlined at build time);
# the secret stays server-only — it signs user tokens and authorizes seeding.
STREAM_API_KEY="your-stream-key"
STREAM_API_SECRET="your-stream-secret"

# ── Server ───────────────────────────────────────────────────────────────────
# The Next.js web app origin (CORS allow-list).
WEB_URL="http://localhost:3000"
# Port this API listens on (defaults to 6969 if unset).
PORT="6969"
