# Copy to `.env` and fill in. Loaded by @nestjs/config (ConfigModule.forRoot)
# and validated at boot against src/env.validation.ts — a missing/blank
# required var crashes the process immediately instead of failing per-request.

# ── Database (MongoDB / Mongoose) ────────────────────────────────────────────
# MongoDB connection string. Consumed by Mongoose (`db:check` pings it via
# scripts/db-check.ts). Use your Atlas SRV URI.
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority"

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# The API is guarded by @clerk/express: every /api/* request must carry a
# valid Clerk session token. These are the same keys the web app uses (copy
# them from web/.env.local).
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ── Chat (GetStream.io) ──────────────────────────────────────────────────────
# Stream Chat app credentials. Create an app in the GetStream dashboard
# (https://dashboard.getstream.io) and copy its Key + Secret. The key is handed
# to the web client via POST /api/stream/token (never inlined at build time);
# the secret stays server-only — it signs user tokens and authorizes seeding.
STREAM_API_KEY="your-stream-key"
STREAM_API_SECRET="your-stream-secret"

# ── Payments (SePay / VietQR) ────────────────────────────────────────────────
# sepay-pg-node checkout + IPN (VienTD-Review Phase 4). Merchant credentials
# come from my.sepay.vn (Payment Gateway → Configuration). Use the sandbox
# environment for dev/test — it runs against a real sandbox host
# (pgapi-sandbox.sepay.vn / sandbox.pay.sepay.vn) without moving real money.
# IPN needs a public HTTPS URL SePay can reach — tunnel local dev with ngrok/
# cloudflared and register the tunnel URL + "/api/payments/ipn" in the
# dashboard. api/src/features/payments/sepay.client.ts is the only thing that
# reads these; tests inject a fake client and never hit the network.
SEPAY_ENV="sandbox"
SEPAY_MERCHANT_ID="your-merchant-id"
SEPAY_SECRET_KEY="your-merchant-secret-key"
# Base URL the player is redirected back to after checkout (a booking id is
# appended, e.g. "$SEPAY_RETURN_URL/<bookingId>"). Point it at the web app.
SEPAY_RETURN_URL="http://localhost:3000/dashboard/bookings"

# ── Server ───────────────────────────────────────────────────────────────────
# The Next.js web app origin (CORS allow-list).
WEB_URL="http://localhost:3000"
# Port this API listens on (defaults to 6969 if unset).
PORT="6969"

# ── Booking sweeper (@nestjs/schedule, runs every minute) ───────────────────
# Decision #5's SLA: a pending (paid) reservation the venue hasn't decided on
# within this many minutes silently auto-confirms ("silence = consent").
# Shorten this in dev to see the sweeper fire without waiting 30 minutes.
BOOKING_CONFIRM_SLA_MINUTES="30"
