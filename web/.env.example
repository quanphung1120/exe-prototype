# Copy to `.env.local` and adjust if your API runs elsewhere.

# Browser-facing origin of the Hono API (the dashboard seed lives at /api/seed).
# Must be reachable from the browser.
NEXT_PUBLIC_API_URL="http://localhost:6969"

# Server-side base for the API (dashboard seed fetch).
API_URL="http://localhost:6969"

# Clerk authentication keys — copy from the Clerk dashboard (API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OpenRouter API key for the AI chat route handler.
OPENROUTER_API_KEY=
# Model for the dashboard chatbot. Default is a small reasoning-capable model
# whose chain of thought streams into the UI. Override with any OpenRouter model
# that returns a `reasoning` field (effort is requested as "low" in the route).
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5
