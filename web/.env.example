# Copy to `.env.local` and adjust if your API runs elsewhere.

# Browser-facing origin of the Hono API (the dashboard seed lives at /api/seed).
# Must be reachable from the browser.
NEXT_PUBLIC_API_URL="http://localhost:6969"

# Server-side base for the API (dashboard seed fetch).
API_URL="http://localhost:6969"

# Clerk authentication keys — copy from the Clerk dashboard (API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
