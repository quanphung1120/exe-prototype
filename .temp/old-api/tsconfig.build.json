{
  // Emit config for `pnpm build` — compiles only src into dist. The base
  // tsconfig.json is noEmit and additionally includes test/ (typechecked by
  // `pnpm typecheck`, but kept out of the shipped build).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
