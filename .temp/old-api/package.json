    "@repo/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "hono": "^4.12.26",
    "mongoose": "^8.9.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22.15.0",
    "eslint": "^9",
    "tsx": "^4.20.0",
