# Copy to `.env.local` and adjust if your API runs elsewhere.

# Browser-facing origin of the Hono API (Better Auth lives at /api/auth there).
# Used by the Better Auth React client, so it must be reachable from the browser.
NEXT_PUBLIC_API_URL="http://localhost:6969"

# Server-side base for the API (dashboard seed fetch, server-side session reads).
API_URL="http://localhost:6969"
