# Copy to `.env` and fill in. The API reads these via `import "dotenv/config"`.

# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
# Pooled connection string. Used by the runtime Neon adapter (src/db.ts) and by
# Prisma CLI tasks (migrate/studio/db push) via prisma.config.ts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── Server ───────────────────────────────────────────────────────────────────
# The Next.js web app origin (CORS allow-list).
WEB_URL="http://localhost:3000"
# Port this API listens on (defaults to 6969 if unset).
PORT="6969"
