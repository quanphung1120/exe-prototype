# Copy to `.env` and fill in. The API reads these via `import "dotenv/config"`.

# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
# Pooled connection string. Used by the runtime Neon adapter (src/db.ts) and by
# Prisma CLI tasks (migrate/studio/db push) via prisma.config.ts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── Better Auth ──────────────────────────────────────────────────────────────
# 32+ char secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# This API's own origin (OAuth redirect URIs resolve against it).
BETTER_AUTH_URL="http://localhost:6969"
# The Next.js web app origin (CORS allow-list + base for email links).
WEB_URL="http://localhost:3000"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:6969/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — https://resend.com/api-keys (falls back to console logging if unset)
RESEND_API_KEY=""
EMAIL_FROM="SportMatch AI <onboarding@resend.dev>"
